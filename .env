# Base URL of the MemeFactory API.
# Leave empty if nginx proxies it on the same origin.
# Example: VITE_MEME_FACTORY_URL=https://api.yoursite.com
VITE_MEME_FACTORY_URL=

# Helius RPC for building/sending Solana transactions in the browser.
# api.mainnet-beta.solana.com blocks browser requests — use Helius instead.
VITE_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=34947b77-8666-4115-92e1-d8fe9640ed02
